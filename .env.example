# BNB AI Engine - Environment variables
# Copy to .env and fill in your keys

# Required for market data
CMC_API_KEY=your_coinmarketcap_api_key
TWELVE_DATA_API_KEY=your_twelvedata_api_key

# MongoDB cache (optional). Replace cluster0.xxxxx with your Atlas cluster host; use your real user/password.
# If unset or invalid, the app still runs and uses CMC/Twelve Data directly.
MONGODB_URI=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/arcgenesis?retryWrites=true&w=majority

# Symbols to cache in MongoDB when MONGODB_URI is set (comma-separated). Default: BTC,ETH,BNB,SOL
# TRACKED_SYMBOLS=BTC,ETH,BNB,SOL

# Required for LLM planning and Copilot chat (at least one)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
GEMINI_API_KEY=your_gemini_api_key

# LLM provider and model override (optional)
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash

# Hub infrastructure
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require
INTERNAL_SECRET=your_random_secret_string
JWT_SECRET=your_random_jwt_secret

# Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# HashKey Global exchange (live trading — leave empty for paper only)
HASHKEY_API_KEY=
HASHKEY_SECRET=
HASHKEY_SANDBOX=true

# 0G Mainnet on-chain logging (DecisionLogger / TradeLogger)
ZERO_G_RPC_URL=https://evmrpc.0g.ai
ZERO_G_PRIVATE_KEY=
ZERO_G_CHAIN_ID=16661
ZERO_G_EXPLORER_BASE=https://chainscan.0g.ai

# 0G Compute (TeeML sealed inference) — set LLM_PROVIDER=0g_compute to route
# supervisor + planner LLM calls through TEE-attested provider.
ZERO_G_COMPUTE_PROVIDER=
ZERO_G_COMPUTE_SECRET=
ZERO_G_COMPUTE_SERVING_BROKER=
ZERO_G_COMPUTE_MODEL=
ZERO_G_COMPUTE_SERVICE_URL=

# 0G Storage (Log Layer) — full LLM reasoning + trade detail JSON
ZERO_G_STORAGE_INDEXER_URL=https://indexer-storage-turbo.0g.ai
